{
  "$schema": "https://mintlify.com/docs.json",
  "name": "goenv",
  "theme": "luma",
  "colors": {
    "primary": "#3D9970",
    "light": "#E8F5EF",
    "dark": "#1A4A33"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/andreimerlescu/goenv"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/andreimerlescu/goenv"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "CLI Reference",
            "pages": [
              "cli/flags",
              "cli/reading",
              "cli/writing",
              "cli/exporting",
              "cli/configuration"
            ]
          },
          {
            "group": "env Package",
            "pages": [
              "library/overview",
              "library/types",
              "library/conditionals",
              "library/configuration"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Type Functions",
            "pages": [
              "api/bool",
              "api/string",
              "api/int",
              "api/float",
              "api/duration",
              "api/list",
              "api/map"
            ]
          },
          {
            "group": "Control Functions",
            "pages": [
              "api/exists",
              "api/truthy",
              "api/validation",
              "api/set-unset"
            ]
          }
        ]
      }
    ]
  }
