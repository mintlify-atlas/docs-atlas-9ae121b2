  "projectDescription": "A Go CLI tool and library for reading, writing, and transforming .env files across multiple formats and environments.",
  "theme": "luma",
  "primaryColor": "#3D9970",
  "lightColor": "#E8F5EF",
  "darkColor": "#1A4A33",
